---
import type { HeroData } from '@core/content/types'
const { data } = Astro.props as { data: HeroData }
---

<section class="ui-section">
  <div class="flow">
    <h1 class="ui-text-title ui-text-title-1">{data.title}</h1>
    <h2 class="ui-text-title ui-text-title-2">{data.subtitle}</h2>
    <p>{data.text}</p>
  </div>
  <p>
    {data.text3}
  </p>
  <p>
    Want to see how the preview part works today? Try the <a href="https://www.namepreview.app/demo/woodnames?name=Emma"
      >Namepreview demo</a
    >
  </p>
  <div class="flex flex-col flow">
    <h3 class="ui-text-title ui-text-title-3">{data.text2}</h3>
    <input type="text" disabled value="Kenzie, Koryn, Sofia" class="pa-s" />
    <button class="ui-button pa-s" type="submit" id="try">Try the demo</button>
  </div>
</section>

<script>
  const names = document.querySelector('#previewNames')
  const demoBtn = document.querySelector('#try') as HTMLButtonElement

  demoBtn.addEventListener('click', () => {
    showNames()
  })

  function showNames() {
    names?.classList.remove('hidden')
  }
</script>
